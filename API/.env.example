# ─────────────────────────────────────────────────────────────
# PLANTILLA de variables de entorno para StockFinder.
# 1) Copia este archivo a  API/.env   (ese .env NO se sube al repo)
# 2) Rellena cada valor con tu clave real.
# NUNCA pongas claves reales en este archivo .example ni en el chat.
# ─────────────────────────────────────────────────────────────

# Financial Modeling Prep  → https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Finnhub                  → https://finnhub.io/dashboard
FINNHUB_API_KEY=

# FRED (macro)             → https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Charles Schwab (bróker + market data · OAuth 2.0)  → https://developer.schwab.com
# Registra una app, activa "Market Data" y "Accounts and Trading".
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1
# Ruta donde se guardan los tokens tras el login OAuth (archivo IGNORADO por git)
SCHWAB_TOKEN_PATH=API/schwab_token.json

# Robinhood (OPCIONAL · login de usuario, no es API pública oficial)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
# Opcional: token/semilla MFA si usas 2FA
ROBINHOOD_MFA_TOKEN=
